import rclpy
from rclpy.node import Node
from std_msgs.msg import String
from sensor_msgs.msg import Image, CameraInfo
from geometry_msgs.msg import PoseArray, Pose
from cv_bridge import CvBridge
import numpy as np
import json
import tf2_ros
import tf2_geometry_msgs
from geometry_msgs.msg import PointStamped

class CoordTransformNode(Node):
    def __init__(self):
        super().__init__('coord_transform')
        self.bridge = CvBridge()
        self.fx = self.fy = self.cx = self.cy = None
        self.latest_depth = None

        self.create_subscription(String, '/detected_chairs', self.chairs_callback, 10)
        self.create_subscription(Image, '/depth_camera/depth_image', self.depth_callback, 10)
        self.create_subscription(CameraInfo, '/depth_camera/camera_info', self.info_callback, 10)

        self.pub = self.create_publisher(PoseArray, '/empty_chairs_map', 10)
        self.tf_buffer = tf2_ros.Buffer()
        self.tf_listener = tf2_ros.TransformListener(self.tf_buffer, self)
        self.get_logger().info('CoordTransformNode started')

    def info_callback(self, msg):
        if self.fx is None:
            self.fx = msg.k[0]
            self.fy = msg.k[4]
            self.cx = msg.k[2]
            self.cy = msg.k[5]
            self.get_logger().info(f'Camera info received: fx={self.fx:.1f}')

    def depth_callback(self, msg):
        self.latest_depth = self.bridge.imgmsg_to_cv2(msg, desired_encoding='passthrough')

    def chairs_callback(self, msg):
        if self.latest_depth is None or self.fx is None:
            return

        chairs = json.loads(msg.data)
        if not chairs:
            return

        pose_array = PoseArray()
        pose_array.header.stamp = self.get_clock().now().to_msg()
        pose_array.header.frame_id = 'map'

        for chair in chairs:
            px, py = chair['cx'], chair['cy']

            # depth 값 (미터)
            h, w = self.latest_depth.shape[:2]
            if px >= w or py >= h:
                continue
            depth = float(self.latest_depth[py, px])
            if not np.isfinite(depth) or depth <= 0.1 or depth > 10.0:
                continue

            # 픽셀 → 카메라 좌표
            x_cam = (px - self.cx) * depth / self.fx
            y_cam = (py - self.cy) * depth / self.fy
            z_cam = depth

            # 카메라 좌표 → 지도 좌표 (TF 변환)
            point = PointStamped()
            point.header.frame_id = 'camera_frame'
            point.header.stamp = self.get_clock().now().to_msg()
            point.point.x = z_cam
            point.point.y = -x_cam
            point.point.z = -y_cam

            try:
                transformed = self.tf_buffer.transform(point, 'map', timeout=rclpy.duration.Duration(seconds=0.1))
                pose = Pose()
                pose.position.x = transformed.point.x
                pose.position.y = transformed.point.y
                pose.position.z = 0.0
                pose.orientation.w = 1.0
                pose_array.poses.append(pose)
                self.get_logger().info(
                    f'Chair at map: ({transformed.point.x:.2f}, {transformed.point.y:.2f})'
                )
            except Exception as e:
                self.get_logger().warn(f'TF transform failed: {e}')

        if pose_array.poses:
            self.pub.publish(pose_array)

def main(args=None):
    rclpy.init(args=args)
    node = CoordTransformNode()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
